generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sucursal {
  id               String             @id @default(uuid())
  nombre           String             @unique
  direccion        String?
  activa           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  principal        Boolean            @default(false)
  movimientosStock         MovimientoStock[] @relation("MovimientoOrigen")
  movimientosStockDestino MovimientoStock[] @relation("MovimientoDestino")
  inventario       SucursalProducto[]
  tickets          TicketReparacion[]
  usuarios         Usuario[]
  ventas           Venta[]
}

model SucursalProducto {
  sucursalId String
  productoId String
  stock      Int      @default(0)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@id([sucursalId, productoId])
  @@index([sucursalId])
  @@index([productoId])
}

model Usuario {
  id                       String             @id @default(uuid())
  nombre                   String
  rol                      RolUsuario
  email                    String             @unique
  password_hash            String
  porcentaje_comision_base Float              @default(0.40)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  sucursalId               String?
  permisos                 Json?

  gana_comision            Boolean            @default(true)
  gana_salario             Boolean            @default(false)
  salario_base_usd         Float              @default(0)
  tickets_asignados        TicketReparacion[]
  sucursal                 Sucursal?          @relation(fields: [sucursalId], references: [id])
  ventas_realizadas        Venta[]
  movimientos_stock        MovimientoStock[]

  @@index([sucursalId])
}

model Cliente {
  id        String             @id @default(uuid())
  nombre    String
  cedula    String             @unique
  telefono  String
  correo    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tickets   TicketReparacion[]
  ventas    Venta[]
}

model Producto {
  id                    String             @id @default(uuid())
  sku                   String             @unique
  nombre                String
  marca_comp            String?
  modelo_comp           String?
  categoria             CategoriaProducto  @default(REPUESTO)
  propiedad             TipoPropiedad      @default(PROPIA)
  propietario           String?
  stock_actual          Int                @default(0)
  stock_minimo          Int                @default(2)
  costo_usd             Float
  precio_usd            Float
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  activo                Boolean            @default(true)
  movimientos           MovimientoStock[]
  inventario_sucursales SucursalProducto[]
  tickets               Ticket_Producto[]
  ventas                Venta_Producto[]
  egresos               TransaccionFinanciera[]

  @@index([categoria])
  @@index([propiedad])
}

model MovimientoStock {
  id                 String         @id @default(uuid())
  productoId         String
  tipo               TipoMovimiento
  cantidad           Int
  referencia         String?
  nota               String?
  createdAt          DateTime       @default(now())
  actualizar_costo   Boolean        @default(false)
  costo_unitario_usd Float?
  sucursalId         String?
  sucursalDestinoId  String?
  usuarioId          String?
  producto           Producto       @relation(fields: [productoId], references: [id])
  sucursal           Sucursal?      @relation("MovimientoOrigen", fields: [sucursalId], references: [id])
  sucursalDestino    Sucursal?      @relation("MovimientoDestino", fields: [sucursalDestinoId], references: [id])
  usuario            Usuario?       @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([tipo])
  @@index([createdAt])
  @@index([sucursalId])
  @@index([usuarioId])
}

model Servicio {
  id         String            @id @default(uuid())
  nombre     String
  precio_usd Float
  createdAt  DateTime          @default(now())
  tickets    Ticket_Servicio[]
}

model TicketReparacion {
  id                  String                  @id @default(uuid())
  clienteId           String
  tecnicoId           String?
  equipo              String?
  tipo_equipo         String                  @default("Smartphone")
  marca               String
  modelo              String
  imei                String?
  clave               String?
  patron_visual       String?
  checklist           Json?
  falla               String
  falla_reportada     String?
  observaciones       String?
  estado              EstadoTicket            @default(RECIBIDO)
  costo_repuestos_usd Float                   @default(0)
  precio_total_usd    Float                   @default(0)
  porcentaje_tecnico  Float                   @default(0.40)
  fecha_ingreso       DateTime                @default(now())
  fecha_entrega       DateTime?
  sucursalId          String?
  pagos               Pago[]
  cliente             Cliente                 @relation(fields: [clienteId], references: [id])
  sucursal            Sucursal?               @relation(fields: [sucursalId], references: [id])
  tecnico             Usuario?                @relation(fields: [tecnicoId], references: [id])
  repuestos           Ticket_Producto[]
  servicios           Ticket_Servicio[]
  transacciones       TransaccionFinanciera[]

  @@index([estado])
  @@index([fecha_ingreso])
  @@index([sucursalId])
}

model Ticket_Producto {
  id                   String           @id @default(uuid())
  ticketId             String
  productoId           String
  cantidad             Int              @default(1)
  precio_congelado_usd Float
  costo_congelado_usd  Float
  producto             Producto         @relation(fields: [productoId], references: [id])
  ticket               TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Ticket_Servicio {
  id                   String           @id @default(uuid())
  ticketId             String
  servicioId           String
  precio_cobrado_usd   Float
  comision_tecnico_usd Float
  servicio             Servicio         @relation(fields: [servicioId], references: [id])
  ticket               TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Venta {
  id                    String                  @id @default(uuid())
  clienteId             String?
  vendedorId            String?
  subtotal_usd          Float
  descuento_usd         Float                   @default(0)
  total_usd             Float
  estado                EstadoVenta             @default(PENDIENTE)
  createdAt             DateTime                @default(now())
  numero                Int                     @unique @default(autoincrement())
  sucursalId            String?
  tasas_cambio_snapshot Json?
  pagos                 Pago[]
  transacciones         TransaccionFinanciera[]
  cliente               Cliente?                @relation(fields: [clienteId], references: [id])
  sucursal              Sucursal?               @relation(fields: [sucursalId], references: [id])
  vendedor              Usuario?                @relation(fields: [vendedorId], references: [id])
  items                 Venta_Producto[]

  @@index([estado])
  @@index([createdAt])
  @@index([sucursalId])
}

model Venta_Producto {
  id                   String   @id @default(uuid())
  ventaId              String
  productoId           String
  cantidad             Int      @default(1)
  precio_congelado_usd Float
  costo_congelado_usd  Float
  producto             Producto @relation(fields: [productoId], references: [id])
  venta                Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
}

model Moneda {
  id          String   @id @default(uuid())
  codigo      String   @unique
  nombre      String?
  tasa_cambio Float    @default(1)
  updatedAt   DateTime @updatedAt
  pagos       Pago[]
}

model Pago {
  id                 String            @id @default(uuid())
  ticketId           String?
  ventaId            String?
  monedaId           String
  monto_moneda_local Float
  equivalente_usd    Float
  referencia         String?
  fecha_pago         DateTime          @default(now())
  metodo             MetodoPago
  tasa_cambio_usada  Float?
  moneda             Moneda            @relation(fields: [monedaId], references: [id])
  ticket             TicketReparacion? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  venta              Venta?            @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([fecha_pago])
}

model TransaccionFinanciera {
  id        String            @id @default(uuid())
  tipo      TipoTransaccion
  monto_usd Float
  concepto  String
  categoria String?
  ticketId  String?
  ventaId   String?
  productoId String?
  esFijo    Boolean           @default(false)
  createdAt DateTime          @default(now())
  ticket    TicketReparacion? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  venta     Venta?            @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  producto  Producto?         @relation(fields: [productoId], references: [id], onDelete: SetNull)

  @@index([tipo])
  @@index([createdAt])
  @@index([categoria])
}

model GastoRecurrente {
  id           String           @id @default(uuid())
  concepto     String
  monto_usd    Float
  categoria    String?          @default("OTROS")
  frecuencia   FrecuenciaGasto  @default(MENSUAL)
  proximaFecha DateTime
  activo       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([proximaFecha])
  @@index([activo])
}

model Marca {
  id        String   @id @default(uuid())
  nombre    String   @unique
  createdAt DateTime @default(now())
  modelos   Modelo[]
}

model Modelo {
  id        String   @id @default(uuid())
  nombre    String
  marcaId   String
  createdAt DateTime @default(now())
  marca     Marca    @relation(fields: [marcaId], references: [id], onDelete: Cascade)

  @@unique([nombre, marcaId])
  @@index([marcaId])
}

model Configuracion {
  id                 Int      @id @default(1)
  nombre_local       String
  porcentaje_defecto Float    @default(0.40)
  updatedAt          DateTime @updatedAt
}

enum RolUsuario {
  ADMIN
  TECNICO
  VENDEDOR
}

enum EstadoTicket {
  RECIBIDO
  EN_REVISION
  ESPERANDO_REPUESTO
  REPARADO
  ENTREGADO
  ABANDONO
}

enum CategoriaProducto {
  EQUIPO
  ACCESORIO
  REPUESTO
}

enum TipoPropiedad {
  PROPIA
  PRESTADA
}

enum EstadoVenta {
  PENDIENTE
  PAGADA
  ANULADA
}

enum TipoMovimiento {
  ENTRADA
  SALIDA_REPARACION
  SALIDA_VENTA
  AJUSTE
  DEVOLUCION
  TRASLADO
}

enum TipoTransaccion {
  INGRESO
  EGRESO
}

enum MetodoPago {
  EFECTIVO
  PAGO_MOVIL
  ZELLE
  TRANSFERENCIA
  BINANCE
  PUNTO_DE_VENTA
}

enum FrecuenciaGasto {
  DIARIO
  SEMANAL
  MENSUAL
}
