generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum RolUsuario {
  ADMIN
  TECNICO
  VENDEDOR
}

enum EstadoTicket {
  RECIBIDO
  EN_REVISION
  ESPERANDO_REPUESTO
  REPARADO
  ENTREGADO
  ABANDONO
}

enum CategoriaProducto {
  EQUIPO     // Teléfonos, tablets completos
  ACCESORIO  // Fundas, cargadores, audífonos
  REPUESTO   // Pantallas, baterías, flex
}

enum TipoPropiedad {
  PROPIA     // Mercancía comprada por el local
  PRESTADA   // Mercancía en consignación
}

enum EstadoVenta {
  PENDIENTE
  PAGADA
  ANULADA
}

enum TipoMovimiento {
  ENTRADA           // Compra / reposición
  SALIDA_REPARACION // Repuesto usado en ticket
  SALIDA_VENTA      // Producto vendido
  AJUSTE            // Ajuste manual de inventario
  DEVOLUCION        // Devolución de producto
}

enum TipoTransaccion {
  INGRESO  // Cobro de reparación, venta
  EGRESO   // Compra de inventario, pago a técnico, gastos
}

enum MetodoPago {
  EFECTIVO
  PAGO_MOVIL
  ZELLE
  TRANSFERENCIA
  BINANCE
}

// ==========================================
// SUCURSALES  (Feature 3)
// ==========================================

model Sucursal {
  id        String   @id @default(uuid())
  nombre    String   @unique
  direccion String?
  activa    Boolean  @default(true)

  // Relaciones
  usuarios         Usuario[]
  inventario       SucursalProducto[]
  ventas           Venta[]
  tickets          TicketReparacion[]
  movimientosStock MovimientoStock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stock por sucursal (pivot)
model SucursalProducto {
  sucursalId String
  productoId String
  stock      Int      @default(0)

  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([sucursalId, productoId])
  @@index([sucursalId])
  @@index([productoId])
}

// ==========================================
// USUARIOS
// ==========================================

model Usuario {
  id                       String              @id @default(uuid())
  nombre                   String
  rol                      RolUsuario
  email                    String              @unique
  password_hash            String

  porcentaje_comision_base Float               @default(0.40)

  // Feature 4: Sucursal asignada (null = sin restricción / ADMIN)
  sucursalId               String?
  sucursal                 Sucursal?           @relation(fields: [sucursalId], references: [id])

  // Feature 5: Permisos granulares por usuario (JSON, nullable = usa defaults por rol)
  permisos                 Json?

  tickets_asignados        TicketReparacion[]
  ventas_realizadas        Venta[]

  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([sucursalId])
}

// ==========================================
// CLIENTES
// ==========================================

model Cliente {
  id        String              @id @default(uuid())
  nombre    String
  cedula    String              @unique
  telefono  String
  correo    String?

  tickets   TicketReparacion[]
  ventas    Venta[]

  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

// ==========================================
// INVENTARIO
// ==========================================

model Producto {
  id           String             @id @default(uuid())
  sku          String             @unique
  nombre       String
  marca_comp   String?
  modelo_comp  String?

  categoria    CategoriaProducto  @default(REPUESTO)
  propiedad    TipoPropiedad      @default(PROPIA)
  propietario  String?
  activo       Boolean            @default(true)

  stock_actual Int                @default(0)  // Stock global (suma de sucursales)
  stock_minimo Int                @default(2)
  costo_usd    Float
  precio_usd   Float

  tickets                  Ticket_Producto[]
  ventas                   Venta_Producto[]
  movimientos              MovimientoStock[]
  inventario_sucursales    SucursalProducto[]   // Feature 3

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([categoria])
  @@index([propiedad])
}

model MovimientoStock {
  id         String         @id @default(uuid())
  productoId String
  tipo       TipoMovimiento
  cantidad   Int
  referencia String?
  nota       String?

  // Feature 2: Precio de proveedor en esta entrada
  costo_unitario_usd Float?
  actualizar_costo   Boolean  @default(false)

  // Feature 3: Sucursal donde ocurrió el movimiento
  sucursalId String?
  sucursal   Sucursal?      @relation(fields: [sucursalId], references: [id])

  producto   Producto       @relation(fields: [productoId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([productoId])
  @@index([tipo])
  @@index([createdAt])
  @@index([sucursalId])
}

// ==========================================
// SERVICIOS
// ==========================================

model Servicio {
  id         String            @id @default(uuid())
  nombre     String
  precio_usd Float
  tickets    Ticket_Servicio[]
  createdAt  DateTime          @default(now())
}

// ==========================================
// REPARACIONES (TICKETS)
// ==========================================

model TicketReparacion {
  id              String       @id @default(uuid())
  clienteId       String
  tecnicoId       String?

  // Feature 3: Sucursal donde se recibió
  sucursalId      String?
  sucursal        Sucursal?    @relation(fields: [sucursalId], references: [id])

  equipo          String?
  tipo_equipo     String       @default("Smartphone")
  marca           String
  modelo          String
  imei            String?
  clave           String?
  patron_visual   String?

  checklist       Json?

  falla           String
  falla_reportada String?
  observaciones   String?
  estado          EstadoTicket @default(RECIBIDO)

  costo_repuestos_usd Float    @default(0)
  precio_total_usd    Float    @default(0)
  porcentaje_tecnico  Float    @default(0.40)

  fecha_ingreso   DateTime     @default(now())
  fecha_entrega   DateTime?

  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  tecnico         Usuario?     @relation(fields: [tecnicoId], references: [id])

  repuestos       Ticket_Producto[]
  servicios       Ticket_Servicio[]
  pagos           Pago[]
  transacciones   TransaccionFinanciera[]

  @@index([estado])
  @@index([fecha_ingreso])
  @@index([sucursalId])
}

model Ticket_Producto {
  id                   String           @id @default(uuid())
  ticketId             String
  productoId           String
  cantidad             Int              @default(1)
  precio_congelado_usd Float
  costo_congelado_usd  Float

  ticket               TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  producto             Producto         @relation(fields: [productoId], references: [id])
}

model Ticket_Servicio {
  id                   String           @id @default(uuid())
  ticketId             String
  servicioId           String
  precio_cobrado_usd   Float
  comision_tecnico_usd Float

  ticket               TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  servicio             Servicio         @relation(fields: [servicioId], references: [id])
}

// ==========================================
// VENTAS DIRECTAS
// ==========================================

model Venta {
  id            String        @id @default(uuid())
  numero        Int           @unique @default(autoincrement())
  clienteId     String?
  vendedorId    String?

  // Feature 3: Sucursal donde se realizó la venta
  sucursalId    String?
  sucursal      Sucursal?     @relation(fields: [sucursalId], references: [id])

  subtotal_usd  Float
  descuento_usd Float         @default(0)
  total_usd     Float

  // Feature 1: Snapshot de tasas al momento de la venta { "VES": 36.5, "COP": 4100 }
  tasas_cambio_snapshot Json?

  estado        EstadoVenta   @default(PENDIENTE)

  cliente       Cliente?      @relation(fields: [clienteId], references: [id])
  vendedor      Usuario?      @relation(fields: [vendedorId], references: [id])
  items         Venta_Producto[]
  pagos         Pago[]
  transacciones TransaccionFinanciera[]

  createdAt     DateTime      @default(now())

  @@index([estado])
  @@index([createdAt])
  @@index([sucursalId])
}

model Venta_Producto {
  id                   String   @id @default(uuid())
  ventaId              String
  productoId           String
  cantidad             Int      @default(1)
  precio_congelado_usd Float
  costo_congelado_usd  Float

  venta                Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto             Producto @relation(fields: [productoId], references: [id])
}

// ==========================================
// FINANZAS
// ==========================================

model Moneda {
  id          String   @id @default(uuid())
  codigo      String   @unique
  nombre      String?
  tasa_cambio Float    @default(1)

  pagos       Pago[]
  updatedAt   DateTime @updatedAt
}

model Pago {
  id                 String            @id @default(uuid())
  ticketId           String?
  ventaId            String?
  monedaId           String

  monto_moneda_local Float
  equivalente_usd    Float
  metodo             MetodoPago
  referencia         String?

  // Feature 1: Tasa usada para convertir (snapshot inmutable)
  tasa_cambio_usada  Float?

  fecha_pago         DateTime          @default(now())

  moneda             Moneda            @relation(fields: [monedaId], references: [id])
  ticket             TicketReparacion? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  venta              Venta?            @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([fecha_pago])
}

model TransaccionFinanciera {
  id        String          @id @default(uuid())
  tipo      TipoTransaccion
  monto_usd Float
  concepto  String
  categoria String?

  ticketId  String?
  ventaId   String?

  ticket    TicketReparacion? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  venta     Venta?            @relation(fields: [ventaId], references: [id], onDelete: SetNull)

  createdAt DateTime         @default(now())

  @@index([tipo])
  @@index([createdAt])
  @@index([categoria])
}

// ==========================================
// CATÁLOGO: MARCAS Y MODELOS
// ==========================================

model Marca {
  id        String   @id @default(uuid())
  nombre    String   @unique
  modelos   Modelo[]
  createdAt DateTime @default(now())
}

model Modelo {
  id        String   @id @default(uuid())
  nombre    String
  marcaId   String
  marca     Marca    @relation(fields: [marcaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([nombre, marcaId])
  @@index([marcaId])
}

// ==========================================
// CONFIGURACIÓN GLOBAL
// ==========================================

model Configuracion {
  id                 Int      @id @default(1)
  nombre_local       String
  porcentaje_defecto Float    @default(0.40)
  updatedAt          DateTime @updatedAt
}