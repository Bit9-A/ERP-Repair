generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Sincronizados con el Frontend)
// ==========================================

enum RolUsuario {
  ADMIN
  TECNICO
  VENDEDOR
}

enum EstadoTicket {
  RECIBIDO
  EN_REVISION
  ESPERANDO_REPUESTO
  REPARADO
  ENTREGADO
  ABANDONO
}

// ==========================================
// USUARIOS (Nómina y Comisiones)
// ==========================================

model Usuario {
  id                       String           @id @default(uuid())
  nombre                   String
  rol                      RolUsuario
  email                    String           @unique
  password_hash            String
  
  // Configuración de comisión por defecto
  porcentaje_comision_base Float            @default(0.40) 

  tickets_asignados        TicketReparacion[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

// ==========================================
// CLIENTES (Documentación profesional)
// ==========================================

model Cliente {
  id                  String             @id @default(uuid())
  nombre              String
  cedula              String             @unique // Cédula/DNI para facturación
  telefono            String
  correo              String?
  
  tickets             TicketReparacion[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

// ==========================================
// INVENTARIO (Repuestos y Productos)
// ==========================================

model Producto {
  id            String            @id @default(uuid())
  sku           String            @unique
  nombre        String
  marca_comp    String?           // Marca compatible (ej: Samsung)
  modelo_comp   String?           // Modelo compatible (ej: A54)
  categoria     String            @default("REPUESTO") // REPUESTO, ACCESORIO, HERRAMIENTA
  stock_actual  Int               @default(0)
  stock_minimo  Int               @default(2)
  costo_usd     Float
  precio_usd    Float

  tickets       Ticket_Producto[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ==========================================
// CORE: REPARACIONES
// ==========================================

model TicketReparacion {
  id              Int          @id @default(autoincrement()) // ID numérico para fácil lectura #T-1001
  clienteId       String
  tecnicoId       String?      // Opcional al inicio (RECIBIDO)
  
  // Información del Equipo (Aplanado para Prisma, pero estructurado en el Front)
  tipo_equipo     String       @default("Smartphone")
  marca           String
  modelo          String
  imei            String?
  clave           String?
  patron_visual   String?      // Aquí guardamos el string del patrón (ej: "0,1,2")
  
  // Checklist (Guardado como JSON para flexibilidad)
  // { "camaras": true, "touch": false, ... }
  checklist       Json?        

  falla           String
  estado          EstadoTicket @default(RECIBIDO)
  
  // Finanzas del Ticket
  costo_repuestos_usd Float      @default(0)
  precio_total_usd    Float      @default(0)
  porcentaje_tecnico  Float      @default(0.40) // El % pactado en este ticket específico
  
  fecha_ingreso   DateTime     @default(now())
  fecha_entrega   DateTime?
  
  // Relaciones
  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  tecnico         Usuario?     @relation(fields: [tecnicoId], references: [id])
  
  repuestos_usados Ticket_Producto[]
  pagos            Pago[]

  @@index([estado])
  @@index([fecha_ingreso])
}

// ==========================================
// TABLAS INTERMEDIAS Y FINANZAS
// ==========================================

model Ticket_Producto {
  id                   String           @id @default(uuid())
  ticketId             Int
  productoId           String
  cantidad             Int              @default(1)
  precio_congelado_usd Float            // Precio de venta al momento del ticket
  costo_congelado_usd  Float            // Costo al momento (para cálculo de ganancia real)

  ticket               TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  producto             Producto         @relation(fields: [productoId], references: [id])
}

model Pago {
  id                  String           @id @default(uuid())
  ticketId            Int
  monto_usd           Float
  metodo              String           // EFECTIVO, PAGO_MOVIL, ZELLE, etc.
  referencia          String?
  tasa_dia            Float            @default(1) // Tasa de cambio usada
  
  fecha_pago          DateTime         @default(now())
  ticket              TicketReparacion @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Configuracion {
  id                Int      @id @default(1)
  tasa_bcv          Float    // Tasa oficial para cálculos en moneda local
  nombre_local      String
  porcentaje_defecto Float   @default(0.40)
  updatedAt         DateTime @updatedAt
}